# Supabase project credentials
# Find these in your Supabase project settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key - server-side only, never expose to the client.
# Used by route handlers / scripts that need to bypass RLS (e.g. import pipeline).
SUPABASE_SERVICE_ROLE_KEY=

# eBird API key — get one at https://ebird.org/api/keygen
NEXT_PUBLIC_EBIRD_API_KEY=

# Literature search — OpenAlex/Crossref/Semantic Scholar are keyless; these are optional and improve rate limits
OPENALEX_MAILTO=
CROSSREF_MAILTO=
SEMANTIC_SCHOLAR_API_KEY=

# Biodiversity Heritage Library — requires registration at https://www.biodiversitylibrary.org/api3.aspx
BHL_API_KEY=

# Email (invitations/notifications). EMAIL_PROVIDER unset or unrecognized
# falls back to a console-log no-op — safe for local dev without any of this.
# For Gmail SMTP: SMTP_PASS must be an App Password (Google Account ->
# Security -> App Passwords, requires 2-Step Verification), not the
# account's regular login password — Gmail rejects plain-password SMTP auth.
EMAIL_PROVIDER=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# LLM ranking/extraction for literature (optional — without these, literature search still works,
# it just won't rank/select high-value documents or extract species from them)
ENABLE_LITERATURE_AGENT=
NVIDIA_API_KEY=
